# OpenAI-compatible provider (works with OpenAI, Ollama, vLLM, LM Studio, etc.)
SONALITY_BASE_URL=https://api.openai.com/v1
SONALITY_API_KEY=your-provider-api-key

# Models (single provider for both response and memory tasks)
SONALITY_MODEL=gpt-4.1-mini
SONALITY_ESS_MODEL=gpt-4.1-mini
SONALITY_FAST_LLM_MODEL=gpt-4.1-mini
SONALITY_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
SONALITY_EMBEDDING_DIMENSIONS=4096

# Neo4j + PostgreSQL/pgvector (Path A is required)
SONALITY_NEO4J_URL=bolt://localhost:7687
SONALITY_NEO4J_USER=neo4j
SONALITY_NEO4J_PASSWORD=sonality_password
SONALITY_NEO4J_DATABASE=neo4j

SONALITY_POSTGRES_URL=postgresql://sonality:sonality_password@localhost:5432/sonality
SONALITY_PG_POOL_MIN_SIZE=2
SONALITY_PG_POOL_MAX_SIZE=10

# Optional tuning
# SONALITY_BOOTSTRAP_DAMPENING_UNTIL=10
# SONALITY_OPINION_COOLING_PERIOD=3
# SONALITY_RETRIEVAL_MAX_ITERATIONS=3
# SONALITY_RETRIEVAL_CONFIDENCE_THRESHOLD=0.8
# SONALITY_RETRIEVAL_OVER_FETCH_FACTOR=3
# SONALITY_LOG_LEVEL=INFO
