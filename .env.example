# ═══════════════════════════════════════════════════════════════════════════════
# REASONING MODELS (OpenAI-compatible: OpenRouter, OpenAI, Ollama, vLLM, etc.)
# ═══════════════════════════════════════════════════════════════════════════════
SONALITY_BASE_URL=https://openrouter.ai/api/v1
SONALITY_API_KEY=your-openrouter-api-key

SONALITY_MODEL=anthropic/claude-haiku-4.5
SONALITY_ESS_MODEL=anthropic/claude-haiku-4.5
SONALITY_FAST_LLM_MODEL=anthropic/claude-haiku-4.5

# ═══════════════════════════════════════════════════════════════════════════════
# EMBEDDING MODEL (can use different provider than reasoning models)
# ═══════════════════════════════════════════════════════════════════════════════
SONALITY_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
SONALITY_EMBEDDING_API_KEY=your-openrouter-api-key
SONALITY_EMBEDDING_MODEL=openai/text-embedding-3-small
SONALITY_EMBEDDING_DIMENSIONS=768

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (Neo4j + PostgreSQL/pgvector)
# ═══════════════════════════════════════════════════════════════════════════════
SONALITY_NEO4J_URL=bolt://localhost:7687
SONALITY_NEO4J_USER=neo4j
SONALITY_NEO4J_PASSWORD=sonality_password
SONALITY_NEO4J_DATABASE=neo4j

SONALITY_POSTGRES_URL=postgresql://sonality:sonality_password@localhost:5432/sonality
SONALITY_PG_POOL_MIN_SIZE=2
SONALITY_PG_POOL_MAX_SIZE=10

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL TUNING (uncomment to override defaults)
# ═══════════════════════════════════════════════════════════════════════════════
# SONALITY_FAST_LLM_MAX_TOKENS=1024
# SONALITY_LOG_LEVEL=INFO
# SONALITY_REFLECTION_EVERY=20
