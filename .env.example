# Copy to .env and fill in your values.
# Only variables that differ from defaults need to be set.

# LLM endpoint (OpenAI-compatible; set API_KEY empty for local servers)
SONALITY_BASE_URL=https://api.openai.com/v1
SONALITY_API_KEY=sk-...
SONALITY_MODEL=gpt-4.1-mini

# Embeddings (local Ollama: set SEND_DIMENSIONS=false for nomic-embed-text)
# SONALITY_EMBEDDING_BASE_URL=http://localhost:11434/v1
# SONALITY_EMBEDDING_MODEL=nomic-embed-text        # default
# SONALITY_EMBEDDING_DIMENSIONS=768                # default
# SONALITY_EMBEDDING_SEND_DIMENSIONS=false         # required for Ollama

# PostgreSQL (override if using non-standard port)
# SONALITY_POSTGRES_URL=postgresql://sonality:sonality_password@localhost:5433/sonality

# Optional tuning (all have sensible defaults — only override if needed)
# SONALITY_ESS_MODEL=                  # defaults to SONALITY_MODEL
# SONALITY_FAST_LLM_MAX_TOKENS=4096    # increase for slow/thinking local models
# SONALITY_ASYNC_TIMEOUT=300           # seconds; increase for slow local LLMs (>120s/call)
# SONALITY_REFLECTION_EVERY=20
# SONALITY_OPINION_COOLING_PERIOD=3
# SONALITY_BOOTSTRAP_DAMPENING_UNTIL=10
# SONALITY_LOG_LEVEL=INFO
